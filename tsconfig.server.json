{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "outDir": "./dist-server",
    "rootDir": "./server",
    "declaration": false,
    "sourceMap": true,
    "skipLibCheck": true
  },
  "include": ["server/**/*.ts"]
}